# Keep text files normalized in Git to avoid noisy LF/CRLF warnings on Windows.
* text=auto eol=lf

# Windows scripts should keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
